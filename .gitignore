# macOS
.DS_Store

# Editor / tooling
.idea/
.vscode/
*.swp

# Node (build tooling only — see below for the vendored runtime)
node_modules/
npm-debug.log*

# Python (if any tooling lands here)
__pycache__/
*.pyc
.venv/
.venv-stable/

# Local runtime / state
run/
*.log

# Generated test diagnostics (written only on a failing offline-boot run, #14)
tests/integration/offline-boot-failure.txt

# Secrets — never commit. The YNAB token lives in macOS Keychain, never on disk.
# .env* (not just .env) so every dotenv variant — .env.local, .env.production,
# .env.test, etc. — is blocked, not only the exact filename.
.env*
*.token
config.local.json
# The live tax profile is secret-adjacent personal financial data: it lives in
# the data dir (~/.claude/plugins/data/workbench-ynab-claude-workbench/) outside
# this PUBLIC repo, never in git. This blocks any tax-profile.json created inside
# the repo tree by mistake; the anonymized tax-profile.example.json keeps a
# distinct name and stays tracked.
tax-profile.json
# Secret-adjacent shapes a YNAB-handling repo must never accept (see SECURITY.md):
# private keys, Keychain dumps, and any token-named file.
*.pem
*.key
keychain-dump*
*_token
*access_token*

# NOTE: vendor/ is intentionally TRACKED. The YNAB MCP bundle is vendored into
# this repo on purpose (frozen, offline, reproducible). Do not add vendor/ here.
