{
  "schema_version": 2,
  "budgets": [
    {
      "label": "Personal",
      "role": "personal",
      "budget_name": "<YOUR_PERSONAL_BUDGET_NAME>",
      "monitoring_enabled": true,
      "write_back_enabled": true
    },
    {
      "label": "Business",
      "role": "business",
      "budget_id": "<YOUR_BUSINESS_BUDGET_UUID>",
      "business_category_group": "Business Expenses",
      "tax_profile_path": "~/Documents/Claude/Tax/business-profile.json",
      "monitoring_enabled": true,
      "write_back_enabled": false
    }
  ],
  "default_budget": "Personal",
  "business": {
    "name": "<YOUR_BUSINESS_NAME>",
    "accounts": ["<YOUR_BUSINESS_CHECKING_ACCOUNT>"],
    "category_group": "Business Expenses",
    "expense_categories": ["Software", "Contractors", "Office", "Hosting"]
  },
  "tax_profile": {
    "filing_status": "single",
    "standard_deduction": 0.0,
    "medical_agi_threshold_pct": 0.075,
    "se_tax_rate": 0.153,
    "quarterly_due_dates": ["04-15", "06-15", "09-15", "01-15"],
    "schedules": ["C", "A", "SE", "1"]
  },
  "mapping_rules": [
    {
      "match": { "category_group": "Business Expenses" },
      "schedule": "C",
      "tax_line": "Schedule C — business expenses"
    },
    {
      "match": { "payee_contains": "pharmacy" },
      "schedule": "A",
      "tax_line": "Schedule A — medical & dental"
    },
    {
      "match": { "category": "Self-Employment Tax" },
      "schedule": "SE",
      "tax_line": "Schedule SE — self-employment tax"
    }
  ],
  "persona": {
    "name": "<PERSONA_NAME>",
    "voice_overrides": null
  },
  "report": {
    "output_dir": "~/Documents/Claude/Reports",
    "template_path": null
  },
  "schedules": {
    "review": {
      "cron": "0 7 * * 1",
      "enabled": true
    },
    "monitor": {
      "cron": "0 8 * * *",
      "enabled": true
    }
  },
  "alerts": {
    "enabled": true,
    "large_transaction_amount": 500,
    "unusual_multiplier": 3,
    "budget_overrun_pct": 100,
    "bill_due_lookahead_days": 3,
    "overdrawn": true,
    "channel": "macos-notification"
  },
  "classification": {
    "highThreshold": 0.85,
    "mediumThreshold": 0.6
  }
}
